</div>

  <div class="news-header" style="margin-top: 120px;">
    <h2 class="news-title">お知らせ</h2>
    <p class="news-subtitle">NEWS</p>
  </div>

  <ul class="news-list">
    <% @food.each do |food| %>
      <li class="news-list-item">
        <%= link_to food_path(food), class: "news-link" do %>
          <span class="news-date"><%= food.created_at.strftime('%Y.%m.%d') %></span>
          <span class="news-item-title"><%= food.title %></span>
        <% end %>
      </li>
    <% end %>
  </ul>

  <div class="news-more-btn-container">
    <%= link_to news_list_path, class: "news-more-link" do %>
