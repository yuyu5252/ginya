<%= stylesheet_link_tag 'index', :media => "all" %>

<div class="foods-container">
  <div class="back-to-top">
    <%= link_to "← トップページへ戻る", root_path %>
  </div>

  <article class="news-detail">
    <p class="news-date">
      <%= @food.created_at.strftime('%Y.%m.%d') %>
    </p>

    <h1 class="news-title">
      <%= @food.title %>
    </h1>

    <% if @food.image.attached? %>
      <div class="news-image">
        <%= image_tag @food.image %>
      </div>
    <% end %>

    <div class="news-content">
      <%= @food.about %>
    </div>

    <div class="news-more-btn-container">
      <%= link_to news_list_path, class: "news-more-link" do %>
        お知らせ一覧へ <span class="arrow">＞</span>
      <% end %>
    </div>

    <div class="admin-actions">
      <%= link_to "この記事を編集する", edit_food_path(@food.id), class: "admin-btn edit-btn" %>
      <%= link_to "この投稿を削除する", food_path(@food), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "admin-btn delete-btn" %>
    </div>
  </article>
</div>