<h1>吟家お知らせ</h1>
<h3>新規投稿ページ</h3>
<%= form_for @food do |f| %>

  <div class="field">
    <%= f.label :日付 %>
    <%= f.date_field :date, :size => 30 %>
  </div>


  <div class="field">
    <%= f.label :タイトル  %>
    <%= f.text_field :title, :size => 30 %>
  </div>


  <div class="field">
    <%= f.label :写真  %>
    <%= f.text_field :photo, :size => 10 %>
  </div>


  <div class="field">
    <%= f.label :説明  %>
    <%= f.text_area :about, :size => "30x2" %>
  </div>

  <%= f.submit "投稿する" %>
<% end %>

<%= link_to "一覧に戻る", foods_path %>