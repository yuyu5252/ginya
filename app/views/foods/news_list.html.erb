<%= stylesheet_link_tag 'index', :media => "all" %>

<div class="foods-container" style="font-family: 'Yu Mincho', serif; color: #333; max-width: 1200px; margin: 0 auto; padding: 0 20px;">
  

  <div class="news-header" style="text-align: center; margin-bottom: 60px;">
    <h2 class="news-title" style="font-size: 26px; font-weight: normal; letter-spacing: 0.15em; margin-bottom: 8px;">お知らせ一覧</h2>
    <p class="news-subtitle" style="font-size: 11px; color: #999; letter-spacing: 0.1em; transform: scale(0.9);">ALL NEWS</p>
  </div>

  <div class="news-grid-container">
    <ul class="news-grid">
      <% @foods.each do |food| %>
        <li class="news-item">
          <%= link_to food_path(food) do %>
            <div class="news-grid-title"><%= food.title %></div>
            <div class="news-grid-date"><%= food.created_at.strftime('%Y/%m/%d') %></div>
            
            <% if food.image.attached? %>
              <%= image_tag food.image, class: "news-image" %>
            <% end %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>

</div>